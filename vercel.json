{
    "rootDirectory": "cliente2",
    "buildCommand": "npm install && npm run build:vercel",
    "outputDirectory": "dist/protecci-n-client",
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "$BACKEND_URL/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
